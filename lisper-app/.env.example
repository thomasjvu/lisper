# Optional trained backend path. Leave commented to test the browser-only
# trained Gemma 4 E2B q4f16 model.
# VITE_LISPER_INFERENCE_URL=http://127.0.0.1:8000
# VITE_LISPER_MODEL_LABEL=thomasjvu/lisper-gemma4-e2b-audio-full (remote merged)

# Browser-only trained WebGPU path.
VITE_LISPER_BROWSER_MODEL_ID=thomasjvu/lisper-gemma4-e2b-audio-onnx-q4f16
VITE_LISPER_BROWSER_DTYPE=q4f16

# Public base browser fallback for A/B testing:
# VITE_LISPER_BROWSER_MODEL_ID=onnx-community/gemma-4-E2B-it-ONNX
# VITE_LISPER_BROWSER_DTYPE=q4f16
#
# Experimental mixed 2-bit browser package. This keeps audio, vision, and
# embeddings on the validated q4f16 path and only asks for a q2f16 decoder.
# VITE_LISPER_BROWSER_MODEL_ID=thomasjvu/lisper-gemma4-e2b-audio-onnx-q2f16-experimental
# VITE_LISPER_BROWSER_DTYPE=q2f16-experimental
#
# Emergency escape hatch only while actively developing a future trained ONNX repo.
# The current trained q4f16 repo is marked validated in app config.
# VITE_LISPER_ALLOW_UNVALIDATED_BROWSER_MODEL=true
